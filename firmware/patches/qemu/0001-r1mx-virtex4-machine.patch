From: r1mx <r1mx@r1mx>
Subject: [PATCH 1/3] hw/ppc: add r1mx-virtex4 machine for RED ONE MX emulation

Register r1mx_virtex4.c under CONFIG_PPC405 in meson.build.

--- a/hw/ppc/meson.build
+++ b/hw/ppc/meson.build
@@ -54,7 +54,8 @@ if 'CONFIG_PSERIES' in config_devices
 # PowerPC 4xx boards
 ppc_ss.add(when: 'CONFIG_PPC405', if_true: files(
   'ppc405_boards.c',
-  'ppc405_uc.c'))
+  'ppc405_uc.c',
+  'r1mx_virtex4.c'))
 ppc_ss.add(when: 'CONFIG_PPC440', if_true: files(
   'ppc440_bamboo.c',
   'ppc440_pcix.c', 'ppc440_uc.c'))
