
 PARAMETER VERSION = 2.1.0




BEGIN ppc405_virtex4
 PARAMETER INSTANCE = ppc405_0
 PARAMETER HW_VER = 2.01.a
 PARAMETER C_IDCR_BASEADDR = 0b0100000000
 PARAMETER C_IDCR_HIGHADDR = 0b0111111111
 BUS_INTERFACE DPLB0 = plb
 BUS_INTERFACE IPLB0 = plb
END

BEGIN plb_v46
 PARAMETER INSTANCE = plb
 PARAMETER HW_VER = 1.02.a
END

BEGIN xps_uartlite
 PARAMETER INSTANCE = UartLite_0
 PARAMETER HW_VER = 1.00.a
 PARAMETER C_BAUDRATE = 115200
 PARAMETER C_USE_PARITY = 0
 PARAMETER C_BASEADDR = 0xe0600000
 PARAMETER C_HIGHADDR = 0xe060ffff
 BUS_INTERFACE SPLB = plb
 PORT Interrupt = xps_uartlite_0_ip2intc_irpt
END

